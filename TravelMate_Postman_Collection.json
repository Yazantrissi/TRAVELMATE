                  "});",
                  "const json = pm.response.json();",
                  "pm.test('reply exists', function () {",
                  "  pm.expect(json.reply).to.be.a('string');",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('bot_message')) {",
                  "  pm.environment.set('bot_message', 'اعطيني خطة رحلة ليوم واحد في القاهرة');",
                  "}"
                ]
              }
            }
